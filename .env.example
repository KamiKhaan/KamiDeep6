# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "live" to connect to real Rithmic / Bookmap gateway.
# Set to "mock" to run the built-in simulator (default).
MODE=mock

# ── Rithmic / Bookmap gateway (live mode only) ────────────────────────────────
RITHMIC_WS_URL=wss://your-rithmic-gateway:443
RITHMIC_USER=your_username
RITHMIC_PASSWORD=your_password
RITHMIC_SYSTEM_NAME=Rithmic Paper Trading

# ── Symbol ────────────────────────────────────────────────────────────────────
SYMBOL=GCQ6          # Gold futures – Aug 2026 contract
EXCHANGE=CME

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit frontend ────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
REFRESH_INTERVAL_MS=1000
